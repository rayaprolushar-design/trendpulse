import pandas as pd
import matplotlib.pyplot as plt
import seaborn as sns
import os

# --- 1. Setup ---
# Load the data from Task 3
csv_path = 'data/trends_analysed.csv'
if not os.path.exists(csv_path):
    # Fallback to the clean version if analyzed isn't ready, 
    # though Task 3 should have produced it.
    csv_path = 'data/trends_clean.csv'

df = pd.read_csv(csv_path)

# Create outputs directory
if not os.path.exists('outputs'):
    os.makedirs('outputs')
    print("Created 'outputs/' directory.")

# Set a clean style for plots
sns.set_theme(style="whitegrid")

# --- 2. Chart 1: Top 10 Stories by Score ---
plt.figure(figsize=(10, 6))
top_10 = df.sort_values(by='score', ascending=False).head(10).copy()

# Shorten titles longer than 50 characters
top_10['short_title'] = top_10['title'].apply(lambda x: x[:47] + '...' if len(str(x)) > 50 else x)

sns.barplot(x='score', y='short_title', data=top_10, palette='viridis')
plt.title('Top 10 Trending Stories by Score')
plt.xlabel('Score')
plt.ylabel('Story Title')
plt.tight_layout()
plt.savefig('outputs/chart1_top_stories.png')
plt.show()

# --- 3. Chart 2: Stories per Category ---
plt.figure(figsize=(10, 6))
cat_counts = df['category'].value_counts().reset_index()
cat_counts.columns = ['category', 'count']

sns.barplot(x='category', y='count', data=cat_counts, palette='magma')
plt.title('Number of Stories per Category')
plt.xlabel('Category')
plt.ylabel('Count')
plt.tight_layout()
plt.savefig('outputs/chart2_categories.png')
plt.show()

# --- 4. Chart 3: Score vs Comments ---
plt.figure(figsize=(10, 6))
# If is_popular doesn't exist (e.g. from clean.csv), create a dummy for the plot
if 'is_popular' not in df.columns:
    df['is_popular'] = df['score'] > df['score'].mean()

sns.scatterplot(x='score', y='num_comments', hue='is_popular', data=df, palette={True: 'orange', False: 'blue'})
plt.title('Story Score vs. Number of Comments')
plt.xlabel('Score')
plt.ylabel('Number of Comments')
plt.legend(title='Is Popular')
plt.tight_layout()
plt.savefig('outputs/chart3_scatter.png')
plt.show()

# --- Bonus: Dashboard ---
fig, axes = plt.subplots(1, 3, figsize=(20, 6))
fig.suptitle('TrendPulse Dashboard', fontsize=20)

# Dashboard Subplot 1: Top 10
sns.barplot(ax=axes[0], x='score', y='short_title', data=top_10, palette='viridis')
axes[0].set_title('Top 10 Stories')
axes[0].set_ylabel('') # Remove label to save space

# Dashboard Subplot 2: Categories
sns.barplot(ax=axes[1], x='category', y='count', data=cat_counts, palette='magma')
axes[1].set_title('Stories per Category')

# Dashboard Subplot 3: Scatter
sns.scatterplot(ax=axes[2], x='score', y='num_comments', hue='is_popular', data=df, palette={True: 'orange', False: 'blue'})
axes[2].set_title('Score vs. Comments')

plt.tight_layout(rect=[0, 0.03, 1, 0.95])
plt.savefig('outputs/dashboard.png')
plt.show()

print("All charts and dashboard saved to the 'outputs/' folder.")
